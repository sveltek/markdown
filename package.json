{
  "name": "@sveltek/markdown-workspace",
  "version": "0.0.0",
  "author": "Sveltek",
  "private": true,
  "type": "module",
  "scripts": {
    "build:markdown": "pnpm --filter @sveltek/markdown build",
    "lint:markdown": "eslint packages/markdown",
    "format:markdown": "pnpm --filter @sveltek/markdown format",
    "publish:markdown": "pnpm --filter @sveltek/markdown publish:markdown",
    "format:rehype-highlight": "pnpm --filter @sveltek/rehype-highlight format",
    "build:rehype-highlight": "pnpm --filter @sveltek/rehype-highlight build",
    "publish:rehype-highlight": "pnpm --filter @sveltek/rehype-highlight publish:rehype-highlight",
    "format:rehype-shiki": "pnpm --filter @sveltek/rehype-shiki format",
    "build:rehype-shiki": "pnpm --filter @sveltek/rehype-shiki build",
    "publish:rehype-shiki": "pnpm --filter @sveltek/rehype-shiki publish:rehype-shiki",
    "format:remark-reading-stats": "pnpm --filter @sveltek/remark-reading-stats format",
    "build:remark-reading-stats": "pnpm --filter @sveltek/remark-reading-stats build",
    "publish:remark-reading-stats": "pnpm --filter @sveltek/remark-reading-stats publish:remark-reading-stats",
    "format:remark-toc": "pnpm --filter @sveltek/remark-toc format",
    "build:remark-toc": "pnpm --filter @sveltek/remark-toc build",
    "publish:remark-toc": "pnpm --filter @sveltek/remark-toc publish:remark-toc",
    "dev:play": "pnpm --filter playground-sveltekit dev",
    "build:play": "pnpm --filter playground-sveltekit build",
    "preview:play": "pnpm --filter playground-sveltekit preview",
    "sync:play": "pnpm --filter playground-sveltekit sync",
    "lint:play": "eslint playgrounds/sveltekit",
    "format:play": "pnpm --filter playground-sveltekit format",
    "format:root": "prettier --write . '!playgrounds' '!packages'",
    "create:release": "sh -c 'gh workflow run release --ref main --field package_name=$1' --",
    "bump": "taze -f -r --interactive"
  },
  "devDependencies": {
    "@hypernym/bundler": "^0.32.1",
    "@hypernym/utils": "^3.4.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltek/eslint-config": "^1.1.5",
    "@sveltek/prettier-config": "^1.0.7",
    "@sveltek/tsconfig": "^1.1.1",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "svelte": "^5.53.12",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
